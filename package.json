{
	"name": "@jetienne/perplexity_cli",
	"version": "1.0.4",
	"description": "CLI for searching the web using Perplexity AI",
	"main": "dist/src/cli.js",
	"bin": {
		"perplexity_cli": "./dist/src/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"skills"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeromeetienne/perplexity_cli.git"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x ./dist/src/cli.js",
		"typecheck": "tsc --noEmit",
		"dev": "tsx ./src/cli.ts",
		"start": "node dist/src/cli.js",
		"test": "node --require tsx/cjs --test tests/*.test.ts",
		"prepublishOnly": "npm run build",
		"publish:all": "npm run build && npm version patch && npm publish --access public"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"@perplexity-ai/perplexity_ai": "^0.34.0",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3"
	}
}
